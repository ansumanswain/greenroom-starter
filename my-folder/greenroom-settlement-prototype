<script>
// State
const DEAL = {
  guarantee: 5000,
  pct: 0.80,
  expenseCap: 2500,
  hospCap: 400,
  bonus: { threshold: 22000, amount: 600 },
  marketingRecoup: 900,
};

const EXPENSES = [
  { id: 1, cat: 'sound', desc: 'Sound engineer', amount: 850, absorbed: false },
  { id: 2, cat: 'lights', desc: 'Lighting rig + operator', amount: 600, absorbed: false },
  { id: 3, cat: 'production', desc: 'Stage manager', amount: 300, absorbed: false },
  { id: 4, cat: 'hospitality', desc: 'Green room rider', amount: 400, absorbed: false },
  { id: 5, cat: 'hospitality', desc: 'Whiskey overage (vs $400 cap)', amount: 214, absorbed: true }, // absorbed
  { id: 6, cat: 'security', desc: 'Door + floor security', amount: 350, absorbed: false },
];

let marketingInterpretation = null; // 'inside' | 'outside' | null
let signedOff = false;

function getGross() { return parseFloat(document.getElementById('gross').value) || 0; }
function getFees() { return parseFloat(document.getElementById('fees').value) || 0; }
function getTickets() { return parseFloat(document.getElementById('tickets').value) || 0; }

function fmt(n) {
  return '$' + Math.abs(n).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

function renderExpenses() {
  const tbody = document.getElementById('expense-rows');
  let totalPassed = 0;
  let totalAbsorbed = 0;
  tbody.innerHTML = '';
  EXPENSES.forEach(e => {
    const tr = document.createElement('tr');
    const isOver = e.id === 5; // hospitality overage
    if (!e.absorbed) totalPassed += e.amount;
    else totalAbsorbed += e.amount;
    tr.innerHTML = `
      <td><span class="expense-cat-pill">${e.cat}</span></td>
      <td style="color:${e.absorbed?'var(--ink-400)':'var(--ink-700)'};">
        ${e.desc}
        ${e.absorbed ? '<span class="absorbed-tag">absorbed by venue</span>' : ''}
        ${isOver ? '<span class="over-cap-tag">over hosp. cap</span>' : ''}
      </td>
      <td class="expense-amount ${e.absorbed?'expense-absorbed':''}">${fmt(e.amount)}</td>
    `;
    tbody.appendChild(tr);
  });

  // Add marketing recoup row if it exists
  if (marketingInterpretation) {
    // Show marketing recoup in expenses section only if "inside" cap interpretation
    if (marketingInterpretation === 'inside') {
      const tr = document.createElement('tr');
      tr.innerHTML = `
        <td><span class="expense-cat-pill" style="background:#fff3cd;color:#856404;">marketing</span></td>
        <td style="color:var(--ink-700);">Marketing recoup <span style="font-size:10px;background:#e8f5ee;color:var(--brand-700);padding:1px 5px;border-radius:3px;border:1px solid #c3e6d2;">inside cap · agreed</span></td>
        <td class="expense-amount">${fmt(DEAL.marketingRecoup)}</td>
      `;
      tbody.appendChild(tr);
    }
  }

  document.getElementById('expenses-total-badge').textContent = fmt(totalPassed + totalAbsorbed) + ' entered';

  // Cap warning
  const cappedPassed = Math.min(totalPassed, DEAL.expenseCap);
  if (totalPassed > DEAL.expenseCap) {
    document.getElementById('cap-warning').style.display = 'block';
    document.getElementById('cap-warning-text').textContent = `${fmt(totalPassed)} entered vs ${fmt(DEAL.expenseCap)} cap. Venue absorbs the ${fmt(totalPassed - DEAL.expenseCap)} overage.`;
  } else {
    document.getElementById('cap-warning').style.display = 'none';
  }
}

function recalc() {
  const gross = getGross();
  const fees = getFees();
  const tickets = getTickets();

  // Expenses (passed through, capped)
  const rawPassed = EXPENSES.filter(e => !e.absorbed).reduce((s,e) => s+e.amount, 0);

  // Marketing recoup logic
  let grossDeduction = fees; // always deduct fees from gross to get net
  let expensePassthrough = rawPassed;
  let marketingNote = '';

  if (marketingInterpretation === 'outside') {
    // Marketing recoup is a separate deduction off gross BEFORE net calc
    grossDeduction = fees + DEAL.marketingRecoup;
    marketingNote = 'Marketing recoup deducted from gross (separate from cap)';
  } else if (marketingInterpretation === 'inside') {
    // Marketing recoup is inside the cap — already added to rawPassed
    expensePassthrough = rawPassed + DEAL.marketingRecoup;
    marketingNote = 'Marketing recoup inside expense cap';
  }

  const net = gross - grossDeduction;
  const cappedExpenses = Math.min(expensePassthrough, DEAL.expenseCap);
  const netAfterExpenses = net - cappedExpenses;
  const pctPayout = netAfterExpenses * DEAL.pct;
  const bonusApplied = gross >= DEAL.bonus.threshold ? DEAL.bonus.amount : 0;

  const pctTotal = pctPayout + bonusApplied;
  const guaranteeWins = DEAL.guarantee >= pctTotal;
  const artistTotal = Math.max(DEAL.guarantee, pctTotal);

  // Render worksheet
  const ws = document.getElementById('worksheet-rows');
  const rows = [];

  rows.push({ label: 'Gross box office', value: gross, note: `${tickets} tickets + ${document.getElementById('comps').value||0} comps` });
  rows.push({ label: '— Platform & CC fees (10%)', value: -fees, note: 'Per ticketing platform agreement' });
  if (marketingInterpretation === 'outside') {
    rows.push({ label: '— Marketing recoup (off gross)', value: -DEAL.marketingRecoup, note: 'Separate deduction per deal terms — locked ' + (marketingInterpretation ? '✓' : '') });
  }
  rows.push({ label: `= Net box office`, value: net, note: '', bold: true });
  rows.push({ label: `— Expenses (capped at ${fmt(DEAL.expenseCap)})`, value: -cappedExpenses, note: marketingInterpretation === 'inside' ? 'Includes $900 marketing recoup · ' + marketingNote : 'Sound, lights, production, security' });
  rows.push({ label: `= Net after expenses`, value: netAfterExpenses, note: '', bold: true });
  rows.push({ label: `× ${(DEAL.pct*100).toFixed(0)}% artist split`, value: pctPayout, note: '' });
  if (bonusApplied) {
    rows.push({ label: `+ Performance bonus (gross ≥ ${fmt(DEAL.bonus.threshold)})`, value: bonusApplied, note: `Gross was ${fmt(gross)} — triggered ✓` });
  } else {
    rows.push({ label: `Performance bonus (gross ≥ ${fmt(DEAL.bonus.threshold)})`, value: 0, note: `Gross ${fmt(gross)} < ${fmt(DEAL.bonus.threshold)} — not triggered`, dim: true });
  }
  rows.push({ label: `= % pathway total`, value: pctTotal, note: '', bold: true });

  let html = '';
  rows.forEach(r => {
    const valClass = r.value < 0 ? 'negative' : r.value === 0 ? 'dim' : '';
    const valStr = r.value === 0 ? 'n/a' : (r.value < 0 ? '-' : '') + fmt(Math.abs(r.value));
    html += `<div class="ws-row">
      <div>
        <div class="ws-label" style="${r.bold?'font-weight:600;color:var(--ink-900);':''} ${r.dim?'color:var(--ink-400);':''}">
          ${r.label}
        </div>
        ${r.note ? `<div class="ws-note">${r.note}</div>` : ''}
      </div>
      <div class="ws-value ${valClass} ${r.dim?'dim':''}" style="${r.bold?'font-weight:600;':''}">${valStr}</div>
    </div>`;
  });

  // Divider + vs comparison
  html += `<div class="ws-divider"></div>`;
  html += `<div class="ws-row">
    <div class="ws-label" style="${guaranteeWins?'':'color:var(--ink-400);'}">Guarantee pathway: ${fmt(DEAL.guarantee)} ${guaranteeWins?'← wins':''}</div>
    <div class="ws-value ${guaranteeWins?'':'dim'}">${fmt(DEAL.guarantee)}</div>
  </div>`;
  html += `<div class="ws-row">
    <div class="ws-label" style="${!guaranteeWins?'':'color:var(--ink-400);'}">Percentage pathway: ${fmt(pctTotal)} ${!guaranteeWins?'← wins':''}</div>
    <div class="ws-value ${!guaranteeWins?'':'dim'}">${fmt(pctTotal)}</div>
  </div>`;
  html += `<div class="ws-divider"></div>`;
  html += `<div class="ws-total-row">
    <div class="ws-total-label">Total to artist (whichever greater)</div>
    <div class="ws-total-value">${fmt(artistTotal)}</div>
  </div>`;

  ws.innerHTML = html;

  // Hero
  document.getElementById('hero-amount').textContent = fmt(artistTotal);
  const vsEl = document.getElementById('vs-indicator');
  if (guaranteeWins) {
    document.getElementById('vs-winner-label').textContent = `Guarantee wins · ${fmt(DEAL.guarantee)} vs ${fmt(pctTotal)} pct`;
    vsEl.className = 'vs-pill guarantee-wins';
  } else {
    document.getElementById('vs-winner-label').textContent = `% pathway wins · ${fmt(pctTotal)} vs ${fmt(DEAL.guarantee)} guarantee`;
    vsEl.className = 'vs-pill';
  }

  const formulaBase = `max(${fmt(DEAL.guarantee)}, ${(DEAL.pct*100).toFixed(0)}% × net)`;
  document.getElementById('hero-formula').textContent = marketingInterpretation ? formulaBase : formulaBase + ' · resolve recoup interpretation to finalize';

  // Bar
  document.getElementById('bar-total').textContent = fmt(artistTotal);

  // Audit
  document.getElementById('audit-total').textContent = fmt(artistTotal);

  // Agent preview
  updateAgentPreview(gross, fees, cappedExpenses, pctPayout, bonusApplied, pctTotal, artistTotal, guaranteeWins, netAfterExpenses, net, marketingInterpretation);
}

function updateAgentPreview(gross, fees, cappedExp, pctPayout, bonus, pctTotal, artistTotal, guaranteeWins, netAfterExp, net, interp) {
  const d = new Date();
  const dateStr = d.toLocaleDateString('en-US', {weekday:'long', month:'long', day:'numeric'});
  let interpLine = interp
    ? (interp === 'inside' ? `Marketing recoup ($900): inside expense cap — agreed with agent ${interp==='inside'?'✓':''}` : `Marketing recoup ($900): separate gross deduction — agreed with agent ✓`)
    : `Marketing recoup ($900): PENDING INTERPRETATION — see deal notes`;

  const preview = `SETTLEMENT STATEMENT
The Crescent · Nashville
${dateStr}

Artist: The Midnight Echo
Deal: $5,000 guarantee vs 80% net after expenses

━━━━━━━━━━━━━━━━━━━━━━━━━━━
BOX OFFICE
Gross:                ${fmt(gross)}
Platform + CC fees:   -${fmt(fees)}
Net box office:        ${fmt(net)}

EXPENSES (capped $2,500)
Sound & lights:       -$1,450.00
Production & security:-$650.00
${interp==='inside' ? 'Marketing recoup:     -$900.00 (inside cap)' : ''}
Total passed through: -${fmt(cappedExp)}
${interp==='outside' ? '\nMarketing recoup (off gross): -$900.00' : ''}

SETTLEMENT MATH
Net after expenses:    ${fmt(netAfterExp)}
× 80% artist split:    ${fmt(pctPayout)}
${bonus > 0 ? `+ Performance bonus:   +${fmt(bonus)}` : ''}

% pathway total:       ${fmt(pctTotal)}
Guarantee:             ${fmt(5000)}
Artist receives (greater of): ${fmt(artistTotal)}

━━━━━━━━━━━━━━━━━━━━━━━━━━━
TOTAL TO ARTIST:       ${fmt(artistTotal)}
Wire by:               Monday 9am

Interpretation on file:
${interpLine}

Questions? mariana@thecrescentnashville.com
Receipts available on request.`;

  document.getElementById('agent-preview-text').textContent = preview;
}

function selectInterp(val) {
  marketingInterpretation = val;
  document.getElementById('opt-inside').className = 'radio-opt' + (val==='inside' ? ' selected' : '');
  document.getElementById('opt-outside').className = 'radio-opt' + (val==='outside' ? ' selected' : '');

  const gross = getGross();
  const fees = getFees();
  const rawPassed = EXPENSES.filter(e => !e.absorbed).reduce((s,e) => s+e.amount, 0);

  let pctPathway, label;
  if (val === 'inside') {
    const net = gross - fees;
    const exp = Math.min(rawPassed + DEAL.marketingRecoup, DEAL.expenseCap);
    pctPathway = (net - exp) * DEAL.pct;
    label = `<span class="interp-impact ${pctPathway > 5000 ? 'more' : 'less'}">Artist gets ${fmt(Math.max(5000, pctPathway))} → ${fmt(pctPathway)} pct pathway</span>`;
  } else {
    const net = gross - fees - DEAL.marketingRecoup;
    const exp = Math.min(rawPassed, DEAL.expenseCap);
    pctPathway = (net - exp) * DEAL.pct;
    label = `<span class="interp-impact ${pctPathway > 5000 ? 'more' : 'less'}">Artist gets ${fmt(Math.max(5000, pctPathway))} → ${fmt(pctPathway)} pct pathway</span>`;
  }

  const impactDiv = document.getElementById('interp-impact');
  impactDiv.innerHTML = `<strong>Impact:</strong> ${label} — difference is ${fmt(Math.abs(
    val === 'inside'
      ? (Math.max(5000, (gross-fees-Math.min(rawPassed+DEAL.marketingRecoup,DEAL.expenseCap))*0.8)) - (Math.max(5000, (gross-fees-DEAL.marketingRecoup-Math.min(rawPassed,DEAL.expenseCap))*0.8))
      : 0
  ))} depending on interpretation.`;
  impactDiv.style.display = 'block';

  // Hide ambiguity, show resolved
  document.getElementById('ambiguity-alert').style.display = 'none';
  document.getElementById('resolved-banner').style.display = 'block';

  // Update audit trail
  document.getElementById('interp-audit-entry').innerHTML = `<strong>Interpretation locked</strong> · Marketing recoup: ${val === 'inside' ? 'inside expense cap' : 'separate gross deduction'} — agreed with agent, logged`;

  renderExpenses();
  recalc();
}

function switchTab(tab, el) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('tab-audit').style.display = tab === 'audit' ? '' : 'none';
  document.getElementById('tab-agent').style.display = tab === 'agent' ? '' : 'none';
}

function signOff() {
  const text = document.getElementById('signoff-input').value.trim();
  if (!text) {
    document.getElementById('signoff-input').focus();
    document.getElementById('signoff-input').style.borderColor = '#ef4444';
    setTimeout(() => document.getElementById('signoff-input').style.borderColor = '', 1500);
    return;
  }
  signedOff = true;
  document.getElementById('signoff-btn').disabled = true;
  document.getElementById('signoff-btn').textContent = '✓ Sign-off recorded';
  
  // Add to audit trail
  const ul = document.querySelector('.audit-trail');
  const li = document.createElement('li');
  li.className = 'audit-item';
  li.innerHTML = `<span class="audit-time">Just now</span>
    <span class="audit-event"><strong>TM sign-off recorded</strong> · "${text}" — settlement locked, wire queued for Monday</span>`;
  ul.appendChild(li);

  showToast('Sign-off recorded. Settlement locked.');
}

function showToast(msg) {
  document.getElementById('toast-msg').textContent = msg;
  const t = document.getElementById('toast');
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2800);
}

// Init
renderExpenses();
recalc();
</script>
</body>
</html>

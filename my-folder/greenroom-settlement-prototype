<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Greenroom · Settlement · Vs Deal Calculator</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Instrument+Serif:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&display=swap" rel="stylesheet">
<style>
  :root {
    --ink-900: #0f0f10;
    --ink-700: #2d2d32;
    --ink-500: #6b6b75;
    --ink-400: #8f8f9a;
    --ink-200: #e0e0e8;
    --ink-100: #f0f0f4;
    --canvas: #fafaf9;
    --canvas-soft: #f4f4f2;
    --brand-700: #1a6b4a;
    --brand-600: #1f7d57;
    --brand-100: #e8f5ee;
    --brand-50: #f0faf5;
    --amber-700: #a16207;
    --amber-100: #fef3c7;
    --amber-50: #fffbeb;
    --rose-700: #be123c;
    --rose-100: #ffe4e6;
    --rose-50: #fff1f2;
    --gold: #c9a84c;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }
  
  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--canvas);
    color: var(--ink-900);
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
  }

  /* Layout */
  .shell {
    display: grid;
    grid-template-columns: 220px 1fr;
    min-height: 100vh;
  }

  /* Sidebar */
  .sidebar {
    background: #fff;
    border-right: 1px solid var(--ink-200);
    padding: 20px 0;
    position: sticky;
    top: 0;
    height: 100vh;
    overflow-y: auto;
  }

  .sidebar-logo {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0 18px 18px;
    border-bottom: 1px solid var(--ink-100);
    margin-bottom: 12px;
  }
  .logo-mark {
    width: 28px; height: 28px;
    background: var(--brand-700);
    border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
  }
  .logo-mark svg { width: 16px; height: 16px; }
  .logo-text {
    font-size: 14px;
    font-weight: 600;
    color: var(--ink-900);
    letter-spacing: -0.01em;
  }

  .nav-section {
    padding: 0 10px;
    margin-bottom: 6px;
  }
  .nav-label {
    font-size: 10px;
    font-weight: 500;
    color: var(--ink-400);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0 8px;
    margin-bottom: 4px;
  }
  .nav-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 7px 8px;
    border-radius: 6px;
    font-size: 13px;
    color: var(--ink-500);
    cursor: pointer;
    text-decoration: none;
    transition: all 0.1s;
  }
  .nav-item:hover { background: var(--ink-100); color: var(--ink-700); }
  .nav-item.active { background: var(--brand-50); color: var(--brand-700); font-weight: 500; }
  .nav-dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; opacity: 0.5; }

  /* Main content */
  .main {
    padding: 40px 48px 80px;
    max-width: 860px;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: var(--ink-400);
    margin-bottom: 28px;
  }
  .breadcrumb a { color: var(--ink-400); text-decoration: none; }
  .breadcrumb a:hover { color: var(--ink-700); }
  .breadcrumb-sep { color: var(--ink-200); }

  /* Show header */
  .show-header {
    margin-bottom: 32px;
  }
  .badges {
    display: flex;
    gap: 6px;
    margin-bottom: 12px;
    flex-wrap: wrap;
  }
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 3px 8px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 500;
    border: 1px solid transparent;
  }
  .badge-green { background: var(--brand-50); color: var(--brand-700); border-color: #c3e6d2; }
  .badge-amber { background: var(--amber-50); color: var(--amber-700); border-color: #fde68a; }
  .badge-pulse { width: 6px; height: 6px; border-radius: 50%; background: var(--brand-700); animation: pulse 2s ease-in-out infinite; }
  @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.4; } }

  .show-title {
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: 38px;
    font-weight: 400;
    color: var(--ink-900);
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin-bottom: 6px;
  }
  .show-meta {
    font-size: 13px;
    color: var(--ink-400);
  }

  /* NEW FEATURE CALLOUT */
  .feature-banner {
    background: linear-gradient(135deg, #0f2e20 0%, #1a5438 100%);
    border-radius: 10px;
    padding: 14px 18px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 24px;
  }
  .feature-banner-left {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .feature-icon {
    width: 32px; height: 32px;
    background: rgba(255,255,255,0.12);
    border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .feature-icon svg { width: 16px; height: 16px; color: #7dd5a0; }
  .feature-text { font-size: 13px; color: rgba(255,255,255,0.9); line-height: 1.4; }
  .feature-text strong { color: #fff; font-weight: 600; }
  .feature-tag {
    background: var(--gold);
    color: #1a1a00;
    font-size: 10px;
    font-weight: 700;
    padding: 2px 7px;
    border-radius: 3px;
    letter-spacing: 0.04em;
    flex-shrink: 0;
  }

  /* Section cards */
  .card {
    background: #fff;
    border: 1px solid var(--ink-200);
    border-radius: 10px;
    margin-bottom: 12px;
    overflow: hidden;
  }
  .card-header {
    padding: 16px 20px 14px;
    border-bottom: 1px solid var(--ink-100);
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
  }
  .card-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--ink-900);
    margin-bottom: 2px;
  }
  .card-desc {
    font-size: 12px;
    color: var(--ink-400);
    line-height: 1.4;
  }
  .card-body { padding: 16px 20px; }
  .card-accent-brand { border-top: 2.5px solid var(--brand-700); }
  .card-accent-amber { border-top: 2.5px solid #f59e0b; }

  /* Deal terms */
  .deal-terms-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }
  .deal-term {
    background: var(--canvas-soft);
    border-radius: 7px;
    padding: 11px 14px;
    border: 1px solid var(--ink-100);
  }
  .deal-term-label {
    font-size: 10px;
    font-weight: 500;
    color: var(--ink-400);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 4px;
  }
  .deal-term-value {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 15px;
    font-weight: 600;
    color: var(--ink-900);
  }
  .deal-term-sub {
    font-size: 11px;
    color: var(--ink-400);
    margin-top: 2px;
  }

  .deal-notes-box {
    margin-top: 12px;
    background: var(--canvas-soft);
    border: 1px solid var(--ink-100);
    border-radius: 7px;
    padding: 12px 14px;
    font-size: 12.5px;
    color: var(--ink-700);
    line-height: 1.6;
  }
  .deal-notes-eyebrow {
    font-size: 10px;
    font-weight: 500;
    color: var(--ink-400);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 6px;
  }

  /* Ambiguity alert */
  .ambiguity-alert {
    margin-top: 12px;
    background: var(--amber-50);
    border: 1px solid #fde68a;
    border-radius: 7px;
    padding: 12px 14px;
    display: flex;
    gap: 10px;
  }
  .ambiguity-icon { font-size: 14px; flex-shrink: 0; margin-top: 1px; }
  .ambiguity-title { font-size: 12.5px; font-weight: 600; color: var(--amber-700); margin-bottom: 3px; }
  .ambiguity-body { font-size: 12px; color: #92400e; line-height: 1.5; }
  .ambiguity-resolve-btn {
    margin-top: 8px;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: var(--amber-700);
    color: #fff;
    font-size: 11.5px;
    font-weight: 500;
    padding: 5px 10px;
    border-radius: 5px;
    border: none;
    cursor: pointer;
    font-family: inherit;
  }
  .ambiguity-resolve-btn:hover { background: #854d0e; }

  /* Inputs */
  .input-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .input-group { display: flex; flex-direction: column; gap: 5px; }
  .input-label {
    font-size: 11.5px;
    font-weight: 500;
    color: var(--ink-500);
  }
  .input-row {
    display: flex;
    align-items: center;
    border: 1px solid var(--ink-200);
    border-radius: 6px;
    background: #fff;
    overflow: hidden;
    transition: border-color 0.15s;
  }
  .input-row:focus-within { border-color: var(--brand-600); box-shadow: 0 0 0 2px rgba(31,125,87,0.12); }
  .input-prefix {
    padding: 0 10px;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13px;
    color: var(--ink-400);
    background: var(--canvas-soft);
    border-right: 1px solid var(--ink-200);
    height: 36px;
    display: flex; align-items: center;
  }
  .input-suffix {
    padding: 0 10px;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13px;
    color: var(--ink-400);
    background: var(--canvas-soft);
    border-left: 1px solid var(--ink-200);
    height: 36px;
    display: flex; align-items: center;
  }
  input[type="number"], input[type="text"] {
    border: none;
    outline: none;
    padding: 0 10px;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13px;
    color: var(--ink-900);
    width: 100%;
    height: 36px;
    background: transparent;
    -moz-appearance: textfield;
  }
  input::-webkit-outer-spin-button, input::-webkit-inner-spin-button { -webkit-appearance: none; }
  input[type="checkbox"] { width: 14px; height: 14px; accent-color: var(--brand-700); }

  /* Expense rows */
  .expense-table { width: 100%; border-collapse: collapse; }
  .expense-table th {
    font-size: 10px;
    font-weight: 500;
    color: var(--ink-400);
    text-align: left;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0 0 8px;
    border-bottom: 1px solid var(--ink-100);
  }
  .expense-table th:last-child { text-align: right; }
  .expense-table td {
    padding: 9px 0;
    font-size: 13px;
    border-bottom: 1px solid var(--ink-100);
    vertical-align: middle;
  }
  .expense-table tr:last-child td { border-bottom: none; }
  .expense-cat-pill {
    display: inline-block;
    font-size: 10px;
    padding: 2px 6px;
    border-radius: 3px;
    font-weight: 500;
    background: var(--ink-100);
    color: var(--ink-500);
  }
  .expense-amount { 
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13px;
    text-align: right;
    color: var(--ink-900);
  }
  .expense-absorbed { color: var(--ink-300); text-decoration: line-through; }
  .absorbed-tag {
    font-size: 10px;
    background: var(--brand-50);
    color: var(--brand-700);
    border: 1px solid #c3e6d2;
    padding: 1px 5px;
    border-radius: 3px;
    margin-left: 5px;
    font-weight: 500;
  }
  .over-cap-tag {
    font-size: 10px;
    background: var(--amber-50);
    color: var(--amber-700);
    border: 1px solid #fde68a;
    padding: 1px 5px;
    border-radius: 3px;
    margin-left: 5px;
    font-weight: 500;
  }

  /* Worksheet */
  .worksheet { display: flex; flex-direction: column; }
  .ws-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 9px 0;
    border-bottom: 1px solid var(--ink-100);
    gap: 12px;
  }
  .ws-row:last-child { border-bottom: none; }
  .ws-label { font-size: 13px; color: var(--ink-600); flex: 1; }
  .ws-note { font-size: 11px; color: var(--ink-400); margin-top: 1px; }
  .ws-value {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13.5px;
    color: var(--ink-900);
    white-space: nowrap;
  }
  .ws-value.positive { color: var(--brand-700); }
  .ws-value.negative { color: var(--rose-700); }
  .ws-value.dim { color: var(--ink-400); }
  .ws-divider { border-top: 2px solid var(--ink-200); margin: 4px 0; }
  .ws-total-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 10px 0 4px;
    gap: 12px;
  }
  .ws-total-label { font-size: 13px; font-weight: 600; color: var(--ink-900); }
  .ws-total-value {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 18px;
    font-weight: 700;
    color: var(--ink-900);
  }

  /* Hero total */
  .hero-total {
    text-align: center;
    padding: 36px 20px 32px;
    background: linear-gradient(to bottom, var(--brand-50), #fff);
    border-bottom: 1px solid var(--ink-100);
  }
  .hero-eyebrow {
    font-size: 10px;
    font-weight: 500;
    color: var(--ink-400);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 10px;
  }
  .hero-amount {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 56px;
    font-weight: 700;
    color: var(--ink-900);
    letter-spacing: -0.03em;
    line-height: 1;
    margin-bottom: 8px;
  }
  .hero-formula {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11.5px;
    color: var(--ink-400);
    margin-bottom: 12px;
  }
  .vs-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--brand-50);
    border: 1px solid #c3e6d2;
    border-radius: 20px;
    padding: 5px 14px;
    font-size: 12px;
    color: var(--brand-700);
    font-weight: 500;
  }
  .vs-pill.guarantee-wins { background: var(--amber-50); border-color: #fde68a; color: var(--amber-700); }
  .vs-number { font-family: 'IBM Plex Mono', monospace; font-weight: 700; }

  /* Recoup interpretation */
  .interp-card {
    background: #fff;
    border: 1px solid var(--ink-200);
    border-radius: 10px;
    margin-bottom: 12px;
    overflow: hidden;
  }
  .interp-header {
    padding: 14px 18px 12px;
    background: #fff8ed;
    border-bottom: 1px solid #fde68a;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .interp-title { font-size: 13px; font-weight: 600; color: var(--amber-700); }
  .interp-body { padding: 14px 18px; }
  .interp-row {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    padding: 10px 0;
    border-bottom: 1px solid var(--ink-100);
  }
  .interp-row:last-child { border-bottom: none; }
  .interp-option-label { font-size: 12px; font-weight: 600; color: var(--ink-700); margin-bottom: 2px; }
  .interp-option-desc { font-size: 11.5px; color: var(--ink-400); margin-bottom: 4px; }
  .interp-impact { font-family: 'IBM Plex Mono', monospace; font-size: 12px; }
  .interp-impact.more { color: var(--brand-700); }
  .interp-impact.less { color: var(--rose-700); }

  /* Radio */
  .radio-group { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 8px; }
  .radio-opt {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 7px 12px;
    border: 1.5px solid var(--ink-200);
    border-radius: 6px;
    cursor: pointer;
    font-size: 12.5px;
    color: var(--ink-600);
    transition: all 0.1s;
    background: #fff;
  }
  .radio-opt:hover { border-color: var(--brand-600); color: var(--brand-700); }
  .radio-opt.selected { border-color: var(--brand-600); background: var(--brand-50); color: var(--brand-700); font-weight: 500; }
  .radio-opt input { display: none; }

  /* Signoff section */
  .signoff-area {
    border-top: 1px solid var(--ink-100);
    padding: 16px 20px;
  }
  .signoff-label { font-size: 11.5px; font-weight: 500; color: var(--ink-500); margin-bottom: 8px; }
  .signoff-input {
    width: 100%;
    border: 1.5px solid var(--ink-200);
    border-radius: 7px;
    padding: 10px 14px;
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    color: var(--ink-900);
    resize: none;
    height: 70px;
    outline: none;
    transition: border-color 0.15s;
  }
  .signoff-input:focus { border-color: var(--brand-600); box-shadow: 0 0 0 2px rgba(31,125,87,0.1); }
  .signoff-btn {
    margin-top: 10px;
    display: inline-flex;
    align-items: center;
    gap: 7px;
    background: var(--brand-700);
    color: #fff;
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 500;
    padding: 9px 18px;
    border-radius: 7px;
    border: none;
    cursor: pointer;
    transition: background 0.15s;
  }
  .signoff-btn:hover { background: var(--brand-600); }
  .signoff-btn:disabled { background: var(--ink-300); cursor: default; }

  /* Audit trail */
  .audit-trail { list-style: none; }
  .audit-item {
    display: flex;
    gap: 12px;
    padding: 10px 0;
    border-bottom: 1px solid var(--ink-100);
    font-size: 12.5px;
  }
  .audit-item:last-child { border-bottom: none; }
  .audit-time { font-family: 'IBM Plex Mono', monospace; font-size: 11px; color: var(--ink-400); white-space: nowrap; min-width: 90px; margin-top: 1px; }
  .audit-event { color: var(--ink-700); line-height: 1.4; }
  .audit-event strong { color: var(--ink-900); font-weight: 500; }

  /* Agent preview */
  .agent-preview {
    background: #f8f8fa;
    border: 1px solid var(--ink-200);
    border-radius: 8px;
    padding: 16px 18px;
    font-size: 12.5px;
    color: var(--ink-700);
    line-height: 1.7;
    font-family: 'IBM Plex Mono', monospace;
    white-space: pre-wrap;
  }

  /* Tabs */
  .tabs {
    display: flex;
    gap: 2px;
    border-bottom: 1px solid var(--ink-200);
    margin-bottom: 16px;
  }
  .tab {
    padding: 9px 14px;
    font-size: 12.5px;
    color: var(--ink-400);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    font-weight: 400;
  }
  .tab:hover { color: var(--ink-700); }
  .tab.active { color: var(--brand-700); border-bottom-color: var(--brand-700); font-weight: 500; }

  /* Bottom action bar */
  .action-bar {
    position: fixed;
    bottom: 0;
    left: 220px;
    right: 0;
    background: rgba(255,255,255,0.95);
    backdrop-filter: blur(8px);
    border-top: 1px solid var(--ink-200);
    padding: 14px 48px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    z-index: 100;
  }
  .action-bar-left { font-size: 12.5px; color: var(--ink-400); }
  .action-bar-left strong { color: var(--ink-900); font-weight: 600; font-family: 'IBM Plex Mono', monospace; font-size: 14px; }
  .action-bar-right { display: flex; gap: 8px; align-items: center; }
  .btn-ghost {
    padding: 8px 14px;
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    color: var(--ink-600);
    background: transparent;
    border: 1px solid var(--ink-200);
    border-radius: 7px;
    cursor: pointer;
  }
  .btn-ghost:hover { border-color: var(--ink-400); color: var(--ink-900); }
  .btn-primary {
    padding: 8px 18px;
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: #fff;
    background: var(--brand-700);
    border: none;
    border-radius: 7px;
    cursor: pointer;
  }
  .btn-primary:hover { background: var(--brand-600); }

  /* Toast */
  .toast {
    position: fixed;
    top: 20px;
    right: 24px;
    background: var(--ink-900);
    color: #fff;
    padding: 12px 18px;
    border-radius: 8px;
    font-size: 13px;
    display: flex;
    align-items: center;
    gap: 8px;
    z-index: 999;
    transform: translateY(-80px);
    transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1);
    box-shadow: 0 4px 20px rgba(0,0,0,0.2);
  }
  .toast.show { transform: translateY(0); }
  .toast-icon { font-size: 14px; }

  /* Status badge */
  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 3px 8px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 500;
  }

  /* Responsive compact */
  @media (max-width: 900px) {
    .shell { grid-template-columns: 1fr; }
